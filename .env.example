# Base URL the RTK Query baseApi points at.
# - With MSW on (default dev): any value works (the worker intercepts).
# - Against the real backend: set this to the server, e.g. http://localhost:4000
VITE_API_URL=http://localhost:4000

# MSW mock worker. Default on in dev. Set to "false" to bypass the mock and hit the
# real backend at VITE_API_URL. Always off in production builds regardless.
VITE_ENABLE_MSW=true
