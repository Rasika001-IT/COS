# Base URL the RTK Query baseApi points at.
# In dev this is intercepted by MSW (no real server). When the backend lands,
# point this at it and delete src/api/mocks/ — slice code does not change.
VITE_API_URL=/api

# Toggle the MSW mock worker in dev (default on). Set to "false" to hit a real
# backend at VITE_API_URL instead.
VITE_ENABLE_MOCKS=true
