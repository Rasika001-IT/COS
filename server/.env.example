# ---- Construct OS backend env (Phase A–B subset; full list in DEPLOY.md later) ----
NODE_ENV=development
PORT=4000

# MongoDB connection string (Atlas M0 for local, or Railway private URL in prod).
MONGO_URL=mongodb://127.0.0.1:27017/constructos

# Auth secrets — generate strong random values:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# CORS: comma-separated allowed origins (the Vite dev server here; Vercel domain in prod).
CORS_ORIGINS=http://localhost:5173

# Cookie security — local dev keeps these relaxed; prod (Phase H) flips to secure cross-site.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Cloudflare R2 (S3-compatible) — file uploads (Phase G). Account ID + bucket from
# the Cloudflare dashboard; R2_PUBLIC_BASE_URL is the bucket's public r2.dev URL or
# a custom domain mapped to it.
R2_ACCOUNT_ID=replace-with-your-cloudflare-account-id
R2_ACCESS_KEY_ID=replace-with-your-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-your-r2-secret-access-key
R2_BUCKET=replace-with-your-bucket-name
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxxxxxx.r2.dev
